{
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "https://subadatos-centralganadera.streamlit.app",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}